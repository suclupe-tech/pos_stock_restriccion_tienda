<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="rule_stock_picking_tienda" model="ir.rule">
        <field name="name">Transferencias solo de mi almacén</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="groups" eval="[(4, ref('pos_stock_restriccion_tienda.group_tienda_restringida'))]"/>
        <field name="domain_force">
            ['|',
                ('location_id.warehouse_id','=',user.warehouse_id.id),
                ('location_dest_id.warehouse_id','=',user.warehouse_id.id)
            ]
        </field>
    </record>

    <record id="rule_stock_quant_tienda" model="ir.rule">
        <field name="name">Existencias solo del almacén asignado</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="groups" eval="[(4, ref('pos_stock_restriccion_tienda.group_tienda_restringida'))]"/>
        <field name="domain_force">[('location_id.warehouse_id', '=', user.warehouse_id.id)]</field>
    </record>

    <record id="rule_pos_config_tienda" model="ir.rule">
        <field name="name">Solo punto de venta asignado</field>
        <field name="model_id" ref="point_of_sale.model_pos_config"/>
        <field name="groups" eval="[(4, ref('pos_stock_restriccion_tienda.group_tienda_restringida'))]"/>
        <field name="domain_force">[('id', '=', user.pos_config_id.id)]</field>
    </record>

        <record id="rule_stock_warehouse_tienda" model="ir.rule">
        <field name="name">Solo mi almacén asignado</field>
        <field name="model_id" ref="stock.model_stock_warehouse"/>
        <field name="groups" eval="[(4, ref('pos_stock_restriccion_tienda.group_tienda_restringida'))]"/>
        <field name="domain_force">[('id', '=', user.warehouse_id.id)]</field>
    </record>

    <record id="rule_stock_picking_tienda" model="ir.rule">
    <field name="name">Transferencias relacionadas a mi almacén</field>
    <field name="model_id" ref="stock.model_stock_picking"/>
    <field name="groups" eval="[(4, ref('pos_stock_restriccion_tienda.group_tienda_restringida'))]"/>
    <field name="domain_force">
        ['|',
            ('location_id', 'child_of', user.warehouse_id.view_location_id.id),
            ('location_dest_id', 'child_of', user.warehouse_id.view_location_id.id)
        ]
    </field>
</record>

</odoo>